{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-engineering.local/schemas/experience.schema.json",
  "title": "Global Engineering Experience",
  "type": "object",
  "required": ["id", "type", "scope", "trigger", "lesson", "evidence", "confidence", "status"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "principle",
        "playbook",
        "role_checklist",
        "case",
        "anti_pattern",
        "policy_rule",
        "stack_knowledge",
        "organization_preference"
      ]
    },
    "scope": { "type": "string" },
    "trigger": { "type": "string" },
    "lesson": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": {
      "type": "string",
      "enum": ["candidate", "sandbox", "default", "deprecated"]
    },
    "source_task_id": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
